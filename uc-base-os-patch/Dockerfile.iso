# syntax=docker/dockerfile:1.7

ARG ELEMENTAL_IMAGE=elemental-image:latest
ARG SOURCE_IMAGE=registry.suse.com/elemental/base-os-kernel-default:16.0
ARG SOURCE_ISO_IMAGE=registry.suse.com/elemental/base-os-kernel-default-iso:16.0

FROM ${ELEMENTAL_IMAGE} AS elemental

FROM ${SOURCE_IMAGE} AS base-src

FROM ${SOURCE_ISO_IMAGE} AS iso-src

FROM ${SOURCE_IMAGE} AS patcher

COPY --from=elemental /usr/bin/elemental3ctl /work/elemental3ctl
COPY --from=base-src /usr/lib/modules /work/base-modules
COPY pkg/dracut/modules.d/29elemental-platform-resolver /work/29elemental-platform-resolver
COPY pkg/dracut/modules.d/30elemental-ignition-merge /work/30elemental-ignition-merge
COPY --from=iso-src /iso/ /work/iso-in/

WORKDIR /work
SHELL ["/bin/bash", "-c"]
RUN --mount=type=tmpfs,target=/tmp <<'EOF'
set -euo pipefail

in_iso="$(find iso-in -maxdepth 1 -name '*.iso' -type f | head -n1)"
[ -n "$in_iso" ] || { echo "no ISO found under /iso in source image" >&2; exit 1; }

name="$(basename "$in_iso")"
in_size="$(stat -c%s "$in_iso")"
mkdir -p /out squashfs-root

xorriso -osirrox on -indev "$in_iso" -extract /LiveOS/squashfs.img squashfs.img >/dev/null 2>&1
unsquashfs -no-xattrs -d squashfs-root squashfs.img >/dev/null

cat elemental3ctl > squashfs-root/usr/bin/elemental3ctl
chmod 0755 squashfs-root/usr/bin/elemental3ctl

mkdir -p squashfs-root/usr/lib/dracut/modules.d/29elemental-platform-resolver
cp -a 29elemental-platform-resolver/. squashfs-root/usr/lib/dracut/modules.d/29elemental-platform-resolver/
mkdir -p squashfs-root/usr/lib/dracut/modules.d/30elemental-ignition-merge
cp -a 30elemental-ignition-merge/. squashfs-root/usr/lib/dracut/modules.d/30elemental-ignition-merge/
chmod 0755 \
  squashfs-root/usr/lib/dracut/modules.d/29elemental-platform-resolver/module-setup.sh \
  squashfs-root/usr/lib/dracut/modules.d/29elemental-platform-resolver/elemental-platform-resolver.sh \
  squashfs-root/usr/lib/dracut/modules.d/30elemental-ignition-merge/module-setup.sh \
  squashfs-root/usr/lib/dracut/modules.d/30elemental-ignition-merge/elemental-ignition-merge.sh

found_initrd=0
for base_initrd in base-modules/*/initrd; do
  [ -f "${base_initrd}" ] || continue
  found_initrd=1
  kver="$(basename "$(dirname "${base_initrd}")")"
  mkdir -p "squashfs-root/usr/lib/modules/${kver}"
  cp "${base_initrd}" "squashfs-root/usr/lib/modules/${kver}/initrd"
  lsinitrd "squashfs-root/usr/lib/modules/${kver}/initrd" | grep -F "elemental-platform-resolver.service" >/dev/null || { echo "missing elemental-platform-resolver.service in copied initrd for ${kver}" >&2; exit 1; }
  lsinitrd "squashfs-root/usr/lib/modules/${kver}/initrd" | grep -F "elemental-ignition-merge.service" >/dev/null || { echo "missing elemental-ignition-merge.service in copied initrd for ${kver}" >&2; exit 1; }
  lsinitrd "squashfs-root/usr/lib/modules/${kver}/initrd" | grep -F "kernel/fs/btrfs/btrfs.ko.zst" >/dev/null || { echo "missing btrfs driver in copied initrd for ${kver}" >&2; exit 1; }
done
[ "$found_initrd" -eq 1 ] || { echo "no base initrd found under /work/base-modules" >&2; exit 1; }

file_contexts="squashfs-root/etc/selinux/targeted/contexts/files/file_contexts"
[ -f "$file_contexts" ] || { echo "missing SELinux file contexts: $file_contexts" >&2; exit 1; }
setfiles -n -v -r "$PWD/squashfs-root" "$file_contexts" "$PWD/squashfs-root" 2>&1 \
  | awk -v root="$PWD/squashfs-root/" '
      /^Would relabel / && $NF ~ /:/ {
        path=$3
        label=$NF
        sub("^" root, "", path)
        if (path != "") {
          print path " x security.selinux=" label
        }
      }
    ' > selinux-labels.pseudo
[ -s selinux-labels.pseudo ] || { echo "failed SELinux label pseudo file" >&2; exit 1; }

mksquashfs squashfs-root squashfs-new.img -noappend -quiet -comp gzip -b 1048576 -pf selinux-labels.pseudo

map_args=(
  -rm /LiveOS/squashfs.img --
  -map /work/squashfs-new.img /LiveOS/squashfs.img --
)

while IFS= read -r old_ext; do
  [ -n "$old_ext" ] || continue
  echo "[iso-patch] removing obsolete extension: $old_ext"
  map_args=(-rm "$old_ext" -- "${map_args[@]}")
done < <(xorriso -indev "$in_iso" -find / -name 'elemental3ctl*' 2>/dev/null \
  | awk -F"'" 'NF>=2 && $2 ~ /\/extensions\// {print $2}')

xorriso -indev "$in_iso" -outdev "/out/$name" \
  -boot_image any replay \
  "${map_args[@]}" \
  -commit_eject no

out_size="$(stat -c%s "/out/$name")"
if [ "$out_size" -lt "$in_size" ]; then
  truncate -s "$in_size" "/out/$name"
fi

if ls iso-in/*.iso.sha256 >/dev/null 2>&1; then
  cd /out
  sha256sum "$name" > "$name.sha256"
fi
EOF

FROM scratch
COPY --from=patcher /out/ /iso/
